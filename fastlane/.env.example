# Copy to fastlane/.env (gitignored) or export in your shell.
# Use the same App Store Connect API key as other Alix Kyle apps (Users and Access → Keys).

APP_STORE_CONNECT_API_KEY_ID=
APP_STORE_CONNECT_API_ISSUER_ID=
APP_STORE_CONNECT_API_KEY_BASE64=

# Optional overrides (defaults match Trako / macOS)
# APP_BUNDLE_ID=com.alixkyle.trako
# APP_STORE_PLATFORM=MAC_OS
